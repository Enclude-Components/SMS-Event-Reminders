    <description>Creates an SMS notification record for a given Event record, if the WhoId is a Contact, and if the Contact&apos;s Mobile field is populated.</description>
    <environments>Default</environments>
    <formulas>
        <name>Event_Formatted_End_Date_Time</name>
        <dataType>String</dataType>
        <expression>CASE(WEEKDAY(DATEVALUE({!Event.EndDateTime})),
  1, &quot;Sunday&quot;,
  2, &quot;Monday&quot;,
  3, &quot;Tuesday&quot;,
  4, &quot;Wednesday&quot;,
  5, &quot;Thursday&quot;,
  6, &quot;Friday&quot;,
  7, &quot;Saturday&quot;,
  &quot;&quot;
) + &quot;, &quot; +
TEXT(DAY(DATEVALUE({!Event.EndDateTime}))) + &quot; &quot; +
CASE(MONTH(DATEVALUE({!Event.EndDateTime})),
  1, &quot;January&quot;,
  2, &quot;February&quot;,
  3, &quot;March&quot;,
  4, &quot;April&quot;,
  5, &quot;May&quot;,
  6, &quot;June&quot;,
  7, &quot;July&quot;,
  8, &quot;August&quot;,
  9, &quot;September&quot;,
  10, &quot;October&quot;,
  11, &quot;November&quot;,
  12, &quot;December&quot;,
  &quot;&quot;
) + &quot; &quot; +
TEXT(YEAR(DATEVALUE({!Event.EndDateTime}))) +
&quot; at &quot; +
TEXT(HOUR(TIMEVALUE({!Event.EndDateTime}))) + &quot;:&quot; +
IF(MINUTE(TIMEVALUE({!Event.EndDateTime})) &lt; 10,
  &quot;0&quot; + TEXT(MINUTE(TIMEVALUE({!Event.EndDateTime}))),
  TEXT(MINUTE(TIMEVALUE({!Event.EndDateTime}))))</expression>
    </formulas>
    <formulas>
        <name>Event_Formatted_Start_Date_Time</name>
        <dataType>String</dataType>
        <expression>CASE(WEEKDAY(DATEVALUE({!Event.StartDateTime})),
  1, &quot;Sunday&quot;,
  2, &quot;Monday&quot;,
  3, &quot;Tuesday&quot;,
  4, &quot;Wednesday&quot;,
  5, &quot;Thursday&quot;,
  6, &quot;Friday&quot;,
  7, &quot;Saturday&quot;,
  &quot;&quot;
) + &quot;, &quot; +
TEXT(DAY(DATEVALUE({!Event.StartDateTime}))) + &quot; &quot; +
CASE(MONTH(DATEVALUE({!Event.StartDateTime})),
  1, &quot;January&quot;,
  2, &quot;February&quot;,
  3, &quot;March&quot;,
  4, &quot;April&quot;,
  5, &quot;May&quot;,
  6, &quot;June&quot;,
  7, &quot;July&quot;,
  8, &quot;August&quot;,
  9, &quot;September&quot;,
  10, &quot;October&quot;,
  11, &quot;November&quot;,
  12, &quot;December&quot;,
  &quot;&quot;
) + &quot; &quot; +
TEXT(YEAR(DATEVALUE({!Event.StartDateTime}))) +
&quot; at &quot; +
TEXT(HOUR(TIMEVALUE({!Event.StartDateTime}))) + &quot;:&quot; +
IF(MINUTE(TIMEVALUE({!Event.StartDateTime})) &lt; 10,
  &quot;0&quot; + TEXT(MINUTE(TIMEVALUE({!Event.StartDateTime}))),
  TEXT(MINUTE(TIMEVALUE({!Event.StartDateTime}))))</expression>
    </formulas>
    <formulas>
        <name>SMS_Body</name>
        <dataType>String</dataType>
        <expression>&apos;Event Reminder&apos; + BR() +
&apos;Subject: &apos; + {!Event.Subject} + BR() +
&apos;Start: &apos; + {!Event_Formatted_Start_Date_Time}  + BR() + 
&apos;End: &apos; + {!Event_Formatted_End_Date_Time}</expression>
    </formulas>
